# Copia este archivo a .env y rellena los valores reales.
# NUNCA commitear .env con secretos reales.

NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://linkforge:linkforge_dev@localhost:5432/linkforge
REDIS_URL=redis://localhost:6379

# Genera uno fuerte: openssl rand -base64 48
JWT_SECRET=cambia-esto-por-un-secreto-de-al-menos-32-caracteres

PLATFORM_DOMAIN=linkforge.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# OAuth (Fase 0, siguiente incremento)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Storage (Cloudflare R2)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=linkforge-uploads

# Observabilidad
SENTRY_DSN=
